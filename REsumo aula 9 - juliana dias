        "# os resultados de módulos de elasticidade para dois grupos de concreto. Eles devem ser arrays ou listas de números.\n",
        "\n",
        "modulo_Concreto_A = [28.0, 29.5, 30.1, 28.9, 30.3 ]\n",
        "modulo_Concreto_B = [31.5, 30.0, 32.2, 30.5, 32.6 ]\n",
        "\n",
        "# Utilizando os dados fornecidos pelo usuário para os grupos\n",
        "grupo1 = modulo_Concreto_A\n",
        "grupo2 = modulo_Concreto_B\n",
        "\n",
        "print(f\"Grupo 1 (Concreto A) tem {len(grupo1)} amostras. Média: {np.mean(grupo1):.2f}, Desvio Padrão: {np.std(grupo1):.2f}\")\n",
        "print(f\"Grupo 2 (Concreto B) tem {len(grupo2)} amostras. Média: {np.mean(grupo2):.2f}, Desvio Padrão: {np.std(grupo2):.2f}\")\n",
        "\n"
